{#- COVERED icon system: 24px, 1.8px stroke, currentColor.
    emojiIcon(char) maps the emoji keys editors pick in the CMS onto brand
    SVG marks; unknown emoji fall back to the raw character. -#}
{%- macro _svg(body) -%}
<svg class="icon" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">{{ body | safe }}</svg>
{%- endmacro -%}

{%- macro emojiIcon(char) -%}
{%- set c = (char or "") | trim -%}
{%- if c == "📣" -%}{{ _svg('<path d="M3 11v3l4 1 9 5V4L7 9l-4 2z"/><path d="M16 8a4 4 0 0 1 0 7"/><path d="M8 15.5V19a1.5 1.5 0 0 0 3 0v-2.6"/>') }}
{%- elif c == "💷" or c == "💰" -%}{{ _svg('<circle cx="12" cy="12" r="8.5"/><path d="M9.5 15.5h5.5M10 15.5V10a2.4 2.4 0 0 1 4.4-1.3M8.8 12.2h4.4"/>') }}
{%- elif c == "💛" or c == "❤️" -%}{{ _svg('<path d="M12 20.5C6.5 16 3.5 12.6 3.5 9.4 3.5 6.9 5.4 5 7.8 5c1.7 0 3.2.9 4.2 2.4C13 5.9 14.5 5 16.2 5c2.4 0 4.3 1.9 4.3 4.4 0 3.2-3 6.6-8.5 11.1z" fill="currentColor" stroke="none"/>') }}
{%- elif c == "⏱️" or c == "⏱" -%}{{ _svg('<circle cx="12" cy="13" r="7.5"/><path d="M12 9.5V13l2.6 1.8M9.5 3h5"/>') }}
{%- elif c == "🤝" -%}{{ _svg('<circle cx="8.5" cy="12" r="5.5"/><circle cx="15.5" cy="12" r="5.5"/>') }}
{%- elif c == "📊" -%}{{ _svg('<path d="M4 20V6M4 20h16"/><path d="M9 20v-7M14 20V9M19 20v-4"/>') }}
{%- elif c == "📍" -%}{{ _svg('<path d="M12 21s-6.5-6-6.5-10.5a6.5 6.5 0 0 1 13 0C18.5 15 12 21 12 21z"/><circle cx="12" cy="10.5" r="2.2"/>') }}
{%- elif c == "📈" -%}{{ _svg('<path d="M4 19L10 13l3.5 3.5L20 10"/><path d="M20 14v-4h-4"/>') }}
{%- elif c == "🚫" -%}{{ _svg('<circle cx="12" cy="12" r="8.5"/><path d="M6 6l12 12"/>') }}
{%- elif c == "🛠️" or c == "🛠" -%}{{ _svg('<path d="M14.5 6.5a4 4 0 0 0-5.7 4.6L4 16l3.5 3.5 4.9-4.8a4 4 0 0 0 4.6-5.7l-2.6 2.6-2.5-2.5 2.6-2.6z"/>') }}
{%- elif c == "🧩" -%}{{ _svg('<path d="M9 4h6v3.2a1.8 1.8 0 1 0 0 3.6V14h-3.2a1.8 1.8 0 1 1-3.6 0H5V4h4z"/><path d="M15 14h4v6H9v-4"/>') }}
{%- elif c == "🎓" -%}{{ _svg('<path d="M2.5 9.5L12 5l9.5 4.5L12 14 2.5 9.5z"/><path d="M6.5 11.5V16c0 1.4 2.5 2.5 5.5 2.5s5.5-1.1 5.5-2.5v-4.5"/>') }}
{%- elif c == "🛍️" or c == "🛍" -%}{{ _svg('<path d="M5.5 8h13l-1 12h-11l-1-12z"/><path d="M9 10V6.5a3 3 0 0 1 6 0V10"/>') }}
{%- elif c == "🏟️" or c == "🏟" -%}{{ _svg('<path d="M3 10c0-1.7 4-3 9-3s9 1.3 9 3-4 3-9 3-9-1.3-9-3z"/><path d="M3 10v5c0 1.7 4 3 9 3s9-1.3 9-3v-5"/>') }}
{%- elif c == "🚆" -%}{{ _svg('<rect x="6" y="4" width="12" height="12" rx="2.5"/><path d="M6 11h12M9.5 19.5L8 22M14.5 19.5L16 22M9 16l-1 2h8l-1-2"/><circle cx="9.5" cy="13.5" r="0.4"/><circle cx="14.5" cy="13.5" r="0.4"/>') }}
{%- elif c == "☕" -%}{{ _svg('<path d="M5 9h11v6a4 4 0 0 1-4 4H9a4 4 0 0 1-4-4V9z"/><path d="M16 10h1.5a2.5 2.5 0 0 1 0 5H16M8 5.5c0-1 .8-1 .8-2M12 5.5c0-1 .8-1 .8-2"/>') }}
{%- elif c == "🎥" -%}{{ _svg('<rect x="3" y="7" width="12" height="10" rx="2.5"/><path d="M15 11l6-3v8l-6-3"/>') }}
{%- elif c == "✉️" or c == "✉" -%}{{ _svg('<rect x="3.5" y="5.5" width="17" height="13" rx="2"/><path d="M4 7l8 6 8-6"/>') }}
{%- else -%}<span aria-hidden="true">{{ c }}</span>
{%- endif -%}
{%- endmacro -%}
