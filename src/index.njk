{% import "icons.njk" as ic %}<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#C9DFEF" />
  <script>
    /* Netlify Identity emails (invites, password recovery) link to the site
       root with a token in the hash — forward them to the CMS login page. */
    (function () {
      var h = document.location.hash;
      if (h && /(invite_token|recovery_token|confirmation_token|email_change_token)=/.test(h)) {
        document.location.replace("/cms/" + h);
      }
    })();
  </script>
  <title>{{ site.pageTitle }}</title>
  <meta name="description" content="{{ site.metaDescription }}" />

  <!-- Open Graph -->
  <meta property="og:title" content="{{ site.pageTitle }}" />
  <meta property="og:description" content="{{ site.ogDescription }}" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://coveredaccess.com/" />
  <meta property="og:site_name" content="COVERED" />
  <meta property="og:image" content="https://coveredaccess.com/images/covered-og.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="article:published_time" content="2026-06-28T12:00:00Z" />
  <meta property="article:modified_time" content="2026-07-06T12:00:00Z" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="canonical" href="https://coveredaccess.com/" />
  <link rel="alternate" type="application/atom+xml" title="COVERED updates" href="/feed.xml" />

  <!-- Favicon: stamp-style C -->
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'%3E%3Cpath d='M12 21C6 16 3 12.4 3 9.2 3 6.4 5.1 4.4 7.7 4.4c1.8 0 3.3 1 4.3 2.5 1-1.5 2.5-2.5 4.3-2.5 2.6 0 4.7 2 4.7 4.8 0 3.2-3 6.8-9 11.8z' fill='%23FF671F'/%3E%3C/svg%3E" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600&family=Dancing+Script:wght@600&display=swap" rel="stylesheet" />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://coveredaccess.com/#org",
        "name": "COVERED",
        "url": "https://coveredaccess.com/",
        "email": "{{ site.contactEmail }}",
        "slogan": "Free Period Products, Paid for by Advertising. We got you covered.",
        "description": "COVERED is a UK social enterprise that installs smart wall-mounted dispensers giving out free, plastic-free period products, funded entirely by brands advertising on the dispensers' 32-inch digital screens.",
        "foundingLocation": { "@type": "Place", "name": "Exeter, United Kingdom" },
        "areaServed": "GB",
        "logo": "https://coveredaccess.com/images/covered-og.jpg"
      },
      {
        "@type": "WebSite",
        "@id": "https://coveredaccess.com/#website",
        "url": "https://coveredaccess.com/",
        "name": "{{ site.pageTitle }}",
        "publisher": { "@id": "https://coveredaccess.com/#org" },
        "inLanguage": "en-GB",
        "datePublished": "2026-06-28",
        "dateModified": "2026-07-06"
      },
      {
        "@type": "FAQPage",
        "@id": "https://coveredaccess.com/#faqpage",
        "mainEntity": [
          {%- for item in faq.items %}
          {
            "@type": "Question",
            "name": {{ item.q | dump | replace("<", "\\u003c") | safe }},
            "acceptedAnswer": { "@type": "Answer", "text": {{ item.a | dump | replace("<", "\\u003c") | safe }} }
          }{% if not loop.last %},{% endif %}
          {%- endfor %}
        ]
      }
    ]
  }
  </script>

  <style>
{% include "site-styles.css" %}  </style>
  <noscript><style>.reveal { opacity: 1; transform: none; } .faq-a { max-height: none !important; } .faq-a[hidden] { display: block; }</style></noscript>
</head>
<body>

  <a class="skip-link" href="#top">Skip to content</a>

  <div id="progress" role="presentation"></div>

  <header>
    <div class="container nav">
      <a href="#top" class="logo" aria-label="COVERED home">
        <span class="logo-heart" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21C6 16 3 12.4 3 9.2 3 6.4 5.1 4.4 7.7 4.4c1.8 0 3.3 1 4.3 2.5 1-1.5 2.5-2.5 4.3-2.5 2.6 0 4.7 2 4.7 4.8 0 3.2-3 6.8-9 11.8z"/></svg></span>
        COVERED
      </a>
      <button class="burger" aria-label="Toggle menu" aria-expanded="false" aria-controls="navLinks">
        <span></span><span></span><span></span>
      </button>
      <ul class="nav-links" id="navLinks">
        <li><a href="#how">How it works</a></li>
        <li><a href="#partners">Partners</a></li>
        <li><a href="#venues">For venues</a></li>
        <li><a href="#locations">Locations</a></li>
        <li><a href="/about/">About</a></li>
        <li><a href="#faq">FAQ</a></li>
        <li><a href="#brands" class="btn btn-primary">Advertise with us</a></li>
      </ul>
    </div>
  </header>

  <main id="top">

    <!-- ============ HERO ============ -->
    <section class="hero" aria-label="Introduction">
      <div class="heart-deco floaty" style="width: 72px; height: 72px; top: 24%; right: 10%; --tilt: 14deg;" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21C6 16 3 12.4 3 9.2 3 6.4 5.1 4.4 7.7 4.4c1.8 0 3.3 1 4.3 2.5 1-1.5 2.5-2.5 4.3-2.5 2.6 0 4.7 2 4.7 4.8 0 3.2-3 6.8-9 11.8z"/></svg></div>
      <div class="heart-deco floaty slow" style="width: 46px; height: 46px; bottom: 26%; left: 9%; --tilt: -12deg;" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21C6 16 3 12.4 3 9.2 3 6.4 5.1 4.4 7.7 4.4c1.8 0 3.3 1 4.3 2.5 1-1.5 2.5-2.5 4.3-2.5 2.6 0 4.7 2 4.7 4.8 0 3.2-3 6.8-9 11.8z"/></svg></div>
      <div class="container hero-inner">
        <span class="hero-badge"><span class="dot-pulse" aria-hidden="true"></span> {{ hero.badge }}</span>
        <h1>{{ hero.headlineMain }} <span class="accent">{{ hero.headlineAccent }}</span></h1>

        <div class="hero-stamp-row">
          <span class="stamp" id="heroStamp">{{ hero.stamp }}</span>
        </div>

        <p class="hero-sub">
          {{ hero.subhead }}
        </p>

        <div class="hero-ctas">
          <a href="#brands" class="btn btn-primary">{{ hero.ctaBrand }}</a>
          <a href="#venues" class="btn btn-outline">{{ hero.ctaVenue }}</a>
        </div>

        <p class="hero-scroll"><a href="#problem">{{ hero.scrollText }}</a></p>
      </div>
    </section>

    <!-- ============ MARQUEE ============ -->
    <div class="marquee">
      <button class="marquee-pause" id="marqueePause" aria-label="Pause scrolling venue list" aria-pressed="false">⏸</button>
      <div class="marquee-track" aria-hidden="true">
        <span>Universities</span><span>Train stations</span><span>Stadiums</span><span>Festivals</span><span>Offices</span><span>Shopping centres</span><span>Airports</span><span>Schools</span><span>Community centres</span>
        <span>Universities</span><span>Train stations</span><span>Stadiums</span><span>Festivals</span><span>Offices</span><span>Shopping centres</span><span>Airports</span><span>Schools</span><span>Community centres</span>
      </div>
    </div>
    <p class="visually-hidden">Target venues include universities, train stations, stadiums, festivals, offices, shopping centres, airports, schools and community centres.</p>

    <!-- ============ PROBLEM ============ -->
    <section id="problem" aria-labelledby="problem-title">
      <div class="container">
        <div class="reveal">
          <span class="kicker">{{ problem.kicker }}</span>
          <h2 class="section-title" id="problem-title">{{ problem.title | safe }}</h2>
          <p class="section-sub">
            {{ problem.subtitle }}
          </p>
        </div>

        <div class="stats-grid">
          {%- for stat in problem.stats %}
          <div class="stat-card reveal">
            <div class="stat-num"><span class="count" data-target="{{ stat.number }}">{{ stat.number }}</span>%</div>
            <p class="stat-label">{{ stat.label }}</p>
          </div>
          {%- endfor %}
        </div>

        <p class="stats-source reveal">Source: <a href="{{ problem.sourceUrl }}" target="_blank" rel="noopener">{{ problem.sourceText }}</a>.</p>

        <div class="photo-strip">
          {%- for photo in problem.photos %}
          <figure class="polaroid reveal" style="--tilt: {{ photo.tilt }};">
            <picture><source type="image/webp" srcset="{{ photo.src | replace('.jpg', '-480.webp') }} 480w, {{ photo.src | replace('.jpg', '.webp') }} 1200w" sizes="(max-width: 780px) 92vw, 420px" /><img src="{{ photo.src }}" width="{{ photo.width }}" height="{{ photo.height }}" loading="lazy"
                 alt="{{ photo.alt }}" /></picture>
            <figcaption>{{ photo.caption }}</figcaption>
          </figure>
          {%- endfor %}
        </div>
      </div>
    </section>

    <!-- ============ MODEL ============ -->
    <section class="model-band texture-dots" aria-labelledby="model-title">
      <div class="container">
        <div class="reveal" style="text-align:center;">
          <span class="kicker">{{ model.kicker }}</span>
          <h2 class="section-title" id="model-title">{{ model.title }}</h2>
          <p class="section-sub" style="margin: 0 auto;">
            {{ model.subtitle }}
          </p>
        </div>

        <div class="loop reveal">
          {%- for step in model.steps %}
          <div class="loop-step">
            <div class="loop-emoji" aria-hidden="true">{{ ic.emojiIcon(step.emoji) }}</div>
            <h3>{{ step.title }}</h3>
            <p>{{ step.desc }}</p>
          </div>
          {%- if not loop.last %}<div class="loop-arrow" aria-hidden="true">→</div>{% endif %}
          {%- endfor %}
        </div>

        <div class="conveyor reveal" aria-hidden="true">
          <div class="belt-track">
            <span class="belt-pack">4-PACK</span><span class="belt-pack">FREE</span><span class="belt-pack">4-PACK</span><span class="belt-pack">COVERED</span><span class="belt-pack">4-PACK</span><span class="belt-pack">FREE</span><span class="belt-pack">4-PACK</span><span class="belt-pack">COVERED</span><span class="belt-pack">4-PACK</span><span class="belt-pack">FREE</span><span class="belt-pack">4-PACK</span><span class="belt-pack">COVERED</span><span class="belt-pack">4-PACK</span><span class="belt-pack">FREE</span><span class="belt-pack">4-PACK</span><span class="belt-pack">COVERED</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ HOW IT WORKS / DEMO ============ -->
    <section id="how" aria-labelledby="how-title">
      <div class="container">
        <div class="reveal" style="text-align:center;">
          <span class="kicker">{{ how.kicker }}</span>
          <h2 class="section-title" id="how-title">{{ how.title }}</h2>
          <p class="section-sub" style="margin: 0 auto;">
            {{ how.subtitle }}
          </p>
        </div>

        <ol class="stepper reveal" id="stepper" aria-label="Demo progress">
          <li class="step-chip active" data-step="0" aria-current="step"><span class="n" aria-hidden="true">1</span> Scan the QR</li>
          <li class="step-chip" data-step="1"><span class="n" aria-hidden="true">2</span> Quick check-in</li>
          <li class="step-chip" data-step="2"><span class="n" aria-hidden="true">3</span> A word from our sponsor</li>
          <li class="step-chip" data-step="3"><span class="n" aria-hidden="true">4</span> Covered.</li>
        </ol>

        <div class="demo-card reveal">
          <!-- Machine -->
          <div class="machine-stage" id="machineStage">
            <div class="machine" role="img" aria-label="Illustration of a COVERED wall-mounted dispenser">
              <span class="led" aria-hidden="true"></span>
              <div class="m-screen" id="machineScreen">
                <div class="qr" aria-hidden="true"></div>
              </div>
              <div class="m-label">Covered</div>
              <div class="m-slot" id="machineSlot">
                <div class="pack" id="pack">4-PACK</div>
              </div>
            </div>
            <span class="stamp machine-stamp" id="machineStamp">Covered.</span>
          </div>

          <!-- Phone -->
          <div class="phone">
            <div class="p-screen" id="phoneScreen" aria-live="polite" tabindex="-1">
              <h3>Need a pad or tampon?</h3>
              <p>Scan the QR code on the machine to get started — it's free.</p>
              <button class="btn btn-primary" id="btnScan">Simulate scan</button>
            </div>
          </div>
        </div>

        <p class="demo-note">
          {{ how.demoNote }}
        </p>
      </div>
    </section>

    <div class="wave" aria-hidden="true"><svg viewBox="0 0 1440 70" preserveAspectRatio="none"><path d="M0,40 C240,70 480,10 720,35 C960,60 1200,15 1440,45 L1440,70 L0,70 Z" fill="#1D2452"/></svg></div>

    <!-- ============ FOR BRANDS ============ -->
    <section id="brands" class="dark" aria-labelledby="brands-title">
      <div class="container">
        <div class="reveal brands-head">
          <div>
            <span class="kicker">{{ brands.kicker }}</span>
            <h2 class="section-title" id="brands-title">{{ brands.title | safe }}</h2>
            <p class="section-sub">
              {{ brands.subtitle }}
            </p>
          </div>
          <figure class="polaroid">
            <picture><source type="image/webp" srcset="{{ brands.headerPhoto.src | replace('.jpg', '-480.webp') }} 480w, {{ brands.headerPhoto.src | replace('.jpg', '.webp') }} 1200w" sizes="250px" /><img src="{{ brands.headerPhoto.src }}" width="{{ brands.headerPhoto.width }}" height="{{ brands.headerPhoto.height }}" loading="lazy"
                 alt="{{ brands.headerPhoto.alt }}" /></picture>
            <figcaption>{{ brands.headerPhoto.caption }}</figcaption>
          </figure>
        </div>

        <div class="benefit-grid">
          {%- for b in brands.benefits %}
          <div class="benefit reveal">
            <div class="b-icon" aria-hidden="true">{{ ic.emojiIcon(b.icon) }}</div>
            <h3>{{ b.title }}</h3>
            <p>{{ b.desc }}</p>
          </div>
          {%- endfor %}
        </div>

        <div class="chip-row reveal">
          {%- for chip in brands.chips %}
          <span class="chip">{{ chip | safe }}</span>
          {%- endfor %}
        </div>

        <div class="form-card reveal">
          <h3>{{ brands.formHeading }}</h3>
          <form id="brandForm" name="brand-enquiry" method="POST" data-netlify="true" netlify-honeypot="bot-field" novalidate>
            <input type="hidden" name="form-name" value="brand-enquiry" /><p class="hp-field" aria-hidden="true"><label>Leave this empty: <input name="bot-field" tabindex="-1" autocomplete="off" /></label></p>
            <div class="form-grid">
              <div class="field">
                <label for="bName">Your name <span class="req" aria-hidden="true">*</span></label>
                <input type="text" id="bName" name="name" autocomplete="name" required />
              </div>
              <div class="field">
                <label for="bCompany">Company <span class="req" aria-hidden="true">*</span></label>
                <input type="text" id="bCompany" name="company" autocomplete="organization" required />
              </div>
              <div class="field">
                <label for="bEmail">Work email <span class="req" aria-hidden="true">*</span></label>
                <input type="email" id="bEmail" name="email" autocomplete="email" required />
              </div>
              <div class="field">
                <label for="bBudget">Indicative monthly budget</label>
                <select id="bBudget" name="budget">
                  <option value="">Prefer not to say</option>
                  <option>Under £500</option>
                  <option>£500 – £2,000</option>
                  <option>£2,000 – £5,000</option>
                  <option>£5,000+</option>
                </select>
              </div>
              <div class="field">
                <label for="bTiming">Preferred campaign timing</label>
                <input type="text" id="bTiming" name="timing" placeholder="e.g. Sept – Dec 2026" />
              </div>
              <div class="field full">
                <label for="bMsg">What are you looking to achieve?</label>
                <textarea id="bMsg" name="message" placeholder="Campaign goals, timing, locations of interest…"></textarea>
              </div>
            </div>
            <div class="form-actions">
              <button type="submit" class="btn btn-primary">{{ brands.formButton }}</button>
              <span class="form-hint">{{ brands.formHint }}</span>
            </div>
          </form>
        </div>
      </div>
    </section>

    <div class="wave flip" aria-hidden="true"><svg viewBox="0 0 1440 70" preserveAspectRatio="none"><path d="M0,40 C240,70 480,10 720,35 C960,60 1200,15 1440,45 L1440,70 L0,70 Z" fill="#1D2452"/></svg></div>

    <!-- ============ PARTNERS ============ -->
    <section id="partners" aria-labelledby="partners-title">
      <div class="container">
        <div class="reveal">
          <span class="kicker">{{ partners.kicker }}</span>
          <h2 class="section-title" id="partners-title">{{ partners.title | safe }}</h2>
          <p class="section-sub">
            {{ partners.subtitle }}
          </p>
        </div>

        <div class="partner-grid">
          {%- for slot in partners.slots %}
          {%- if slot.founding %}
          <div class="p-slot founding reveal">
            <span class="stamp">Reserved</span>
            <span class="slot-logo">{{ slot.logoText }}</span>
            <small>{{ slot.category | safe }}</small>
          </div>
          {%- else %}
          <div class="p-slot reveal"><span class="slot-logo">{{ slot.logoText }}</span><small>{{ slot.category | safe }}</small></div>
          {%- endif %}
          {%- endfor %}
        </div>

        <p class="reveal" style="margin-top: 2rem; text-align: center;">
          <a href="#brands" class="btn btn-primary">{{ partners.ctaButton }}</a>
        </p>
      </div>
    </section>

    <!-- ============ FOR VENUES ============ -->
    <section id="venues" aria-labelledby="venues-title">
      <div class="container">
        <div class="reveal">
          <span class="pilot-ribbon">{{ venues.ribbon }}</span>
          <span class="kicker" style="display:block;">{{ venues.kicker }}</span>
          <h2 class="section-title" id="venues-title">{{ venues.title | safe }}</h2>
          <p class="section-sub">
            {{ venues.subtitle }}
          </p>
        </div>

        <div class="cols-2">
          <div class="list-card reveal">
            <h3>{{ ic.emojiIcon("🛠️") }} We handle</h3>
            <ul>
              {%- for item in venues.weHandle %}
              <li>{{ item }}</li>
              {%- endfor %}
            </ul>
          </div>
          <div class="list-card wants reveal">
            <h3>{{ ic.emojiIcon("🧩") }} You provide</h3>
            <ul>
              {%- for item in venues.youProvide %}
              <li>{{ item }}</li>
              {%- endfor %}
            </ul>
          </div>
        </div>

        <div class="form-card light-form reveal">
          <h3>{{ venues.formHeading }}</h3>
          <form id="venueForm" name="venue-enquiry" method="POST" data-netlify="true" netlify-honeypot="bot-field" novalidate>
            <input type="hidden" name="form-name" value="venue-enquiry" /><p class="hp-field" aria-hidden="true"><label>Leave this empty: <input name="bot-field" tabindex="-1" autocomplete="off" /></label></p>
            <div class="form-grid">
              <div class="field">
                <label for="vName">Your name <span class="req" aria-hidden="true">*</span></label>
                <input type="text" id="vName" name="name" autocomplete="name" required />
              </div>
              <div class="field">
                <label for="vVenue">Venue / organisation <span class="req" aria-hidden="true">*</span></label>
                <input type="text" id="vVenue" name="venue" autocomplete="organization" required />
              </div>
              <div class="field">
                <label for="vEmail">Email <span class="req" aria-hidden="true">*</span></label>
                <input type="email" id="vEmail" name="email" autocomplete="email" required />
              </div>
              <div class="field">
                <label for="vType">Venue type</label>
                <select id="vType" name="type">
                  <option>University / school</option>
                  <option>Shopping centre / retail</option>
                  <option>Stadium / large venue</option>
                  <option>Transport hub</option>
                  <option>Office / workplace</option>
                  <option>Hospitality</option>
                  <option>Other</option>
                </select>
              </div>
              <div class="field full">
                <label for="vMsg">Anything we should know?</label>
                <textarea id="vMsg" name="message" placeholder="Location, footfall, timelines…"></textarea>
              </div>
            </div>
            <div class="form-actions">
              <button type="submit" class="btn btn-primary">{{ venues.formButton }}</button>
              <span class="form-hint">{{ venues.formHint }}</span>
            </div>
          </form>
        </div>
      </div>
    </section>

    <!-- ============ LOCATIONS ============ -->
    <section id="locations" aria-labelledby="locations-title">
      <div class="container">
        <div class="reveal" style="text-align:center;">
          <span class="kicker">{{ locations.kicker }}</span>
          <h2 class="section-title" id="locations-title">{{ locations.title | safe }}</h2>
          <p class="section-sub" style="margin: 0 auto;">
            {{ locations.subtitle }}
          </p>
        </div>

        <div class="loc-grid">
          <div class="uk-map-wrap reveal">
            <svg class="uk-map" viewBox="{{ locations.svgViewBox }}" role="img" aria-label="{{ locations.svgAriaLabel }}">
              <path class="uk-neighbor" d="{{ locations.neighborPath }}"/>
              <path class="uk-land" d="{{ locations.landPath }}"/>
              <g id="mapPins" aria-hidden="true"></g>
            </svg>
            <div class="map-legend" aria-hidden="true">
              <span><span class="dot live"></span>Pilot city</span>
              <span><span class="dot soon"></span>On the roadmap</span>
            </div>
          </div>

          <div class="reveal">
            <div class="city-chips" id="cityChips" role="group" aria-label="Choose a city to see its status"></div>
            <div class="city-detail" id="cityDetail" aria-live="polite"></div>
            <div class="loc-types">
              <p class="loc-types-title">The kinds of places we're targeting first:</p>
              <div class="chip-row">
                {%- for pt in locations.placeTypes %}
                <span class="chip">{{ ic.emojiIcon(pt.emoji) }} {{ pt.label }}</span>
                {%- endfor %}
              </div>
              <p class="loc-cta">
                <a href="#venues" class="btn btn-outline">{{ locations.ctaButton }}</a>
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ VISION ============ -->
    <section class="vision-band texture-dots" aria-labelledby="vision-title">
      <div class="container">
        <div class="reveal" style="text-align:center;">
          <span class="kicker">{{ vision.kicker }}</span>
          <h2 class="section-title" id="vision-title">{{ vision.title | safe }}</h2>
        </div>

        <div class="timeline">
          {%- for m in vision.milestones %}
          <div class="milestone reveal">
            <span class="phase-tag">{{ m.tag }}</span>
            <h3>{{ m.title }}</h3>
            <p>{{ m.desc }}</p>
          </div>
          {%- endfor %}
        </div>

        <div class="bip reveal">
          <h3>{{ vision.bipTitle }}</h3>
          <p>
            {{ vision.bipText }}
          </p>
          <div class="soon-chips">
            {%- for chip in vision.soonChips %}
            <span class="chip">{{ chip }}</span>
            {%- endfor %}
          </div>
          <form name="launch-notify" method="POST" data-netlify="true" class="notify-form" id="notifyForm">
            <input type="hidden" name="form-name" value="launch-notify" />
            <label class="visually-hidden" for="nEmail">Your email</label>
            <input id="nEmail" type="email" name="email" required placeholder="you@email.com" autocomplete="email" />
            <button class="btn btn-primary" type="submit">Tell me when Exeter goes live</button>
          </form>
        </div>
      </div>
    </section>

    <!-- ============ FAQ ============ -->
    <section id="faq" aria-labelledby="faq-title">
      <div class="container">
        <div class="reveal" style="text-align:center;">
          <span class="kicker">{{ faq.kicker }}</span>
          <h2 class="section-title" id="faq-title">{{ faq.title }}</h2>
        </div>

        <div class="faq-list">
          {%- for item in faq.items %}
          <div class="faq-item reveal">
            <button class="faq-q" aria-expanded="false">
              {{ item.q }}
              <span class="indicator" aria-hidden="true">+</span>
            </button>
            <div class="faq-a"><div class="faq-a-inner">
              {{ item.a }}
            </div></div>
          </div>
          {%- endfor %}
        </div>
      </div>
    </section>

    <!-- ============ CTA ============ -->
    <section aria-label="Get in touch">
      <div class="container">
        <div class="cta-banner reveal">
          <h2>{{ site.ctaBannerTitle }}</h2>
          <p>{{ site.ctaBannerText }}</p>
          <a class="btn btn-light" href="mailto:{{ site.contactEmail }}?subject=COVERED%20—%20Hello">{{ site.ctaBannerButton }}</a>
        </div>
      </div>
    </section>

  </main>

  <!-- ============ FOOTER ============ -->
  <footer>
    <div class="container">
      <div class="foot-grid">
        <div class="foot-brand">
          <a href="#top" class="logo" aria-label="COVERED home">
            <span class="logo-heart" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21C6 16 3 12.4 3 9.2 3 6.4 5.1 4.4 7.7 4.4c1.8 0 3.3 1 4.3 2.5 1-1.5 2.5-2.5 4.3-2.5 2.6 0 4.7 2 4.7 4.8 0 3.2-3 6.8-9 11.8z"/></svg></span>
            COVERED
          </a>
          <p>{{ site.footerTagline }}</p>
        </div>
        <nav class="foot-col" aria-label="Footer — explore">
          <p class="foot-head">Explore</p>
          <ul>
            <li><a href="/#problem">The problem</a></li>
            <li><a href="/#how">How it works</a></li>
            <li><a href="/#locations">Locations</a></li>
            <li><a href="/#faq">FAQ</a></li>
            <li><a href="/about/">About</a></li>
            <li><a href="/privacy/">Privacy</a></li>
          </ul>
        </nav>
        <nav class="foot-col" aria-label="Footer — partner">
          <p class="foot-head">Partner</p>
          <ul>
            <li><a href="/#brands">Advertise with us</a></li>
            <li><a href="/#partners">Partner wall</a></li>
            <li><a href="/#venues">Host a dispenser</a></li>
            <li><a href="mailto:{{ site.contactEmail }}">Contact</a></li>
          </ul>
        </nav>
      </div>
      <div class="foot-bottom">
        <span>© <span id="year"></span> COVERED. All rights reserved.</span>
        <span>Last updated: {{ site.lastUpdated }}</span>
        <span>Built in the open, from Exeter 💛</span>
      </div>
    </div>
  </footer>

  <script>
    (function () {
      "use strict";
      var reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      /* ---------- Footer year ---------- */
      document.getElementById("year").textContent = new Date().getFullYear();

      /* ---------- Scroll progress ---------- */
      var progress = document.getElementById("progress");
      function updateProgress() {
        var h = document.documentElement;
        var max = h.scrollHeight - h.clientHeight;
        progress.style.width = (max > 0 ? (h.scrollTop / max) * 100 : 0) + "%";
      }
      window.addEventListener("scroll", updateProgress, { passive: true });
      window.addEventListener("resize", updateProgress);
      if ("ResizeObserver" in window) {
        new ResizeObserver(updateProgress).observe(document.body);
      }
      updateProgress();

      /* ---------- Mobile nav ---------- */
      var burger = document.querySelector(".burger");
      var navLinks = document.getElementById("navLinks");
      burger.addEventListener("click", function () {
        var open = navLinks.classList.toggle("open");
        burger.setAttribute("aria-expanded", open ? "true" : "false");
      });
      navLinks.addEventListener("click", function (e) {
        if (e.target.tagName === "A") {
          navLinks.classList.remove("open");
          burger.setAttribute("aria-expanded", "false");
        }
      });

      /* ---------- Reveal on scroll ---------- */
      var revealEls = document.querySelectorAll(".reveal");
      if ("IntersectionObserver" in window && !reduced) {
        var ro = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              ro.unobserve(entry.target);
            }
          });
        }, { threshold: 0.12 });
        revealEls.forEach(function (el) { ro.observe(el); });
      } else {
        revealEls.forEach(function (el) { el.classList.add("visible"); });
      }

      /* ---------- Hero stamp ---------- */
      var heroStamp = document.getElementById("heroStamp");
      if (!reduced) {
        /* 1. headline words rise in one by one */
        var heroH1 = document.querySelector(".hero h1");
        var wordIndex = 0;
        function splitWords(node) {
          var parts = node.textContent.split(/(\s+)/);
          var frag = document.createDocumentFragment();
          parts.forEach(function (part) {
            if (!part) { return; }
            if (/^\s+$/.test(part)) { frag.appendChild(document.createTextNode(part)); return; }
            var s = document.createElement("span");
            s.className = "w-rise";
            s.style.animationDelay = (0.05 + wordIndex * 0.04) + "s";
            s.textContent = part;
            frag.appendChild(s);
            wordIndex++;
          });
          return frag;
        }
        Array.prototype.slice.call(heroH1.childNodes).forEach(function (node) {
          if (node.nodeType === 3) {
            heroH1.replaceChild(splitWords(node), node);
          } else if (node.nodeType === 1 && node.tagName !== "BR") {
            Array.prototype.slice.call(node.childNodes).forEach(function (inner) {
              if (inner.nodeType === 3) { node.replaceChild(splitWords(inner), inner); }
            });
          }
        });

        /* 2. stamp slams after the words, with a tiny page shake */
        heroStamp.style.opacity = "0";
        var heroInner = document.querySelector(".hero-inner");
        setTimeout(function () {
          heroStamp.style.opacity = "";
          heroStamp.classList.add("stamp-in");
          setTimeout(function () { heroInner.classList.add("hero-shake"); }, 300);
        }, 700);

        /* 3. floating packs drift in last */
        var decos = document.querySelectorAll(".float-deco, .heart-deco");
        decos.forEach(function (d) { d.style.opacity = "0"; });
        setTimeout(function () {
          decos.forEach(function (d) {
            d.style.transition = "opacity 1s ease";
            d.style.opacity = "";
          });
        }, 1100);
      }

      /* ---------- Marquee pause ---------- */
      var marqueePause = document.getElementById("marqueePause");
      var marqueeEl = marqueePause.closest(".marquee");
      marqueePause.addEventListener("click", function () {
        var paused = marqueeEl.classList.toggle("paused");
        marqueePause.setAttribute("aria-pressed", paused ? "true" : "false");
        marqueePause.textContent = paused ? "▶" : "⏸";
      });

      /* ---------- Animated counters ---------- */
      function animateCount(el) {
        var target = parseInt(el.getAttribute("data-target"), 10);
        if (reduced) { el.textContent = target; return; }
        var start = null;
        var dur = 1300;
        function tick(ts) {
          if (!start) start = ts;
          var p = Math.min((ts - start) / dur, 1);
          var eased = 1 - Math.pow(1 - p, 3);
          el.textContent = Math.round(eased * target);
          if (p < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      }
      var counters = document.querySelectorAll(".count");
      if ("IntersectionObserver" in window) {
        var co = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              animateCount(entry.target);
              co.unobserve(entry.target);
            }
          });
        }, { threshold: 0.6 });
        counters.forEach(function (el) { co.observe(el); });
      } else {
        counters.forEach(function (el) { el.textContent = el.getAttribute("data-target"); });
      }

      /* ---------- Interactive demo ---------- */
      var phoneScreen = document.getElementById("phoneScreen");
      var machineScreen = document.getElementById("machineScreen");
      var machineStamp = document.getElementById("machineStamp");
      var machineStage = document.getElementById("machineStage");
      var pack = document.getElementById("pack");
      var chips = document.querySelectorAll("#stepper .step-chip");
      var confettiColors = ["#E85502", "#3D5BBF", "#E8B4BA", "#1D2452"];

      function setStep(n) {
        chips.forEach(function (chip) {
          var s = parseInt(chip.getAttribute("data-step"), 10);
          var active = s === n;
          var done = s < n;
          chip.classList.toggle("active", active);
          chip.classList.toggle("done", done);
          if (active) { chip.setAttribute("aria-current", "step"); } else { chip.removeAttribute("aria-current"); }
          var marker = chip.querySelector(".sr-state");
          if (!marker) {
            marker = document.createElement("span");
            marker.className = "visually-hidden sr-state";
            chip.appendChild(marker);
          }
          marker.textContent = done ? " (completed)" : "";
        });
      }

      function machineShowQR() {
        machineScreen.innerHTML = '<div class="qr" aria-hidden="true"></div>';
      }
      function machineShowAd() {
        machineScreen.innerHTML =
          '<div class="ad-live"><small>Sponsored</small><strong>Your brand, here 👋</strong></div>';
      }

      function confettiBurst() {
        if (reduced) return;
        for (var i = 0; i < 22; i++) {
          var bit = document.createElement("span");
          bit.className = "confetti-bit";
          bit.style.left = (30 + Math.random() * 40) + "%";
          bit.style.background = confettiColors[i % confettiColors.length];
          bit.style.animationDelay = (Math.random() * 0.25) + "s";
          machineStage.appendChild(bit);
          (function (b) {
            setTimeout(function () { b.remove(); }, 1800);
          })(bit);
        }
      }

      function renderScan(fromReset) {
        setStep(0);
        machineShowQR();
        machineStamp.classList.remove("show");
        pack.classList.remove("drop");
        phoneScreen.innerHTML =
          '<h3>Need a pad or tampon?</h3>' +
          '<p>Scan the QR code on the machine to get started — it\'s free.</p>' +
          '<button class="btn btn-primary" id="btnScan">Simulate scan</button>';
        var btn = document.getElementById("btnScan");
        btn.addEventListener("click", renderVerify);
        if (fromReset === true) { btn.focus(); }
      }

      function renderVerify() {
        setStep(1);
        phoneScreen.innerHTML =
          '<h3>Quick check-in</h3>' +
          '<p>A phone number or email keeps things fair — never spam.</p>' +
          '<input class="p-input" type="text" value="you@example.com" readonly tabindex="-1" aria-label="Example email address" />' +
          '<button class="btn btn-primary" id="btnVerify">Check in →</button>';
        var btn = document.getElementById("btnVerify");
        btn.addEventListener("click", renderAd);
        btn.focus();
      }

      function renderAd() {
        setStep(2);
        machineShowAd();
        phoneScreen.innerHTML =
          '<h3>A word from our sponsor</h3>' +
          '<div class="ad-box"><small>Sponsored</small><strong>Your brand, here 👋</strong></div>' +
          '<div class="ad-progress" aria-hidden="true"><div class="bar" id="adBar"></div></div>' +
          '<p>This short moment pays for the product. Nice one, sponsors.</p>';
        phoneScreen.focus({ preventScroll: true });
        var bar = document.getElementById("adBar");
        var advanced = false;
        function advance() {
          if (advanced) { return; }
          advanced = true;
          renderDone();
        }
        if (reduced) {
          bar.style.width = "100%";
          setTimeout(advance, 500);
        } else {
          // force reflow so the animation always restarts cleanly
          void bar.offsetWidth;
          bar.classList.add("run");
          bar.addEventListener("animationend", advance, { once: true });
          // fallback: browsers throttle animations in background tabs
          setTimeout(advance, 3400);
        }
      }

      function renderDone() {
        setStep(3);
        pack.classList.add("drop");
        machineStamp.classList.add("show");
        confettiBurst();
        phoneScreen.innerHTML =
          '<span class="stamp p-stamp">Covered.</span>' +
          '<h3>You\'re all set</h3>' +
          '<p>Grab your pack from the tray below. That\'s it — no cost, no card, no catch.</p>' +
          '<button class="btn btn-outline" id="btnReset">Run the demo again</button>';
        var btn = document.getElementById("btnReset");
        btn.addEventListener("click", function () { renderScan(true); });
        btn.focus({ preventScroll: true });
      }

      renderScan(false);

      /* ---------- Locations map ---------- */
      var CITY_DATA = ({{ locations.cities | dump | replace("<", "\\u003c") | safe }} || [])
        .filter(function (c) { return c && c.id && isFinite(c.x) && isFinite(c.y); });

      var pinsG = document.getElementById("mapPins");
      var chipsWrap = document.getElementById("cityChips");
      var cityDetail = document.getElementById("cityDetail");
      var SVGNS = "http://www.w3.org/2000/svg";

      function selectCity(id) {
        var c = null;
        CITY_DATA.forEach(function (x) { if (x.id === id) { c = x; } });
        if (!c) { return; }
        document.querySelectorAll(".map-pin").forEach(function (p) {
          p.classList.toggle("selected", p.getAttribute("data-city") === id);
        });
        document.querySelectorAll(".city-chip").forEach(function (ch) {
          ch.setAttribute("aria-pressed", ch.getAttribute("data-city") === id ? "true" : "false");
        });
        cityDetail.innerHTML =
          "<h3>" + c.name + " <span class=\"status-tag " + (c.live ? "live" : "soon") + "\">" +
          (c.live ? "Pilot — recruiting venues" : "On the roadmap") + "</span></h3>" +
          "<p>" + c.blurb + "</p>";
      }

      CITY_DATA.forEach(function (c, idx) {
        var g = document.createElementNS(SVGNS, "g");
        g.setAttribute("class", "map-pin" + (c.live ? " live" : ""));
        g.setAttribute("data-city", c.id);
        // drop order: roadmap cities first, Exeter lands last
        g.style.setProperty("--pin-delay", (c.live ? CITY_DATA.length * 0.12 + 0.25 : idx * 0.12) + "s");
        if (c.live) {
          var ring = document.createElementNS(SVGNS, "circle");
          ring.setAttribute("class", "ring");
          ring.setAttribute("cx", c.x);
          ring.setAttribute("cy", c.y);
          ring.setAttribute("r", 7);
          g.appendChild(ring);
        }
        var core = document.createElementNS(SVGNS, "circle");
        core.setAttribute("class", "core");
        core.setAttribute("cx", c.x);
        core.setAttribute("cy", c.y);
        core.setAttribute("r", c.live ? 7 : 5.5);
        g.appendChild(core);
        var hit = document.createElementNS(SVGNS, "circle");
        hit.setAttribute("cx", c.x);
        hit.setAttribute("cy", c.y);
        hit.setAttribute("r", 16);
        hit.setAttribute("fill", "transparent");
        g.appendChild(hit);
        g.addEventListener("click", function () { selectCity(c.id); });
        pinsG.appendChild(g);

        var chip = document.createElement("button");
        chip.type = "button";
        chip.className = "city-chip";
        chip.setAttribute("data-city", c.id);
        chip.setAttribute("aria-pressed", "false");
        chip.innerHTML = c.name + (c.live ? ' <span class="badge-live">● pilot</span>' : "");
        chip.addEventListener("click", function () { selectCity(c.id); });
        chipsWrap.appendChild(chip);
      });

      selectCity("exeter");

      /* pin-drop entrance when the map scrolls into view */
      var ukMap = document.querySelector(".uk-map");
      function mapConfetti() {
        var wrap = document.querySelector(".uk-map-wrap");
        if (!wrap) { return; }
        for (var i = 0; i < 14; i++) {
          var bit = document.createElement("span");
          bit.className = "confetti-bit";
          bit.style.left = (40 + Math.random() * 10) + "%";
          bit.style.top = "82%";
          bit.style.background = confettiColors[i % confettiColors.length];
          bit.style.animationDelay = (Math.random() * 0.2) + "s";
          wrap.appendChild(bit);
          (function (b) { setTimeout(function () { b.remove(); }, 1800); })(bit);
        }
      }
      if (ukMap && !reduced && "IntersectionObserver" in window) {
        ukMap.classList.add("pins-prep");
        var mapObserver = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              ukMap.classList.add("pins-go");
              setTimeout(mapConfetti, (CITY_DATA.length * 0.12 + 0.25 + 0.45) * 1000);
              mapObserver.unobserve(ukMap);
            }
          });
        }, { threshold: 0.35 });
        mapObserver.observe(ukMap);
      }

      /* ---------- FAQ accordion ---------- */
      var faqItems = document.querySelectorAll(".faq-item");
      function closeFaq(item) {
        var btn = item.querySelector(".faq-q");
        var panel = item.querySelector(".faq-a");
        item.classList.remove("open");
        btn.setAttribute("aria-expanded", "false");
        panel.style.maxHeight = null;
        clearTimeout(panel._hideTimer);
        panel._hideTimer = setTimeout(function () { panel.hidden = true; }, 320);
      }
      faqItems.forEach(function (item, idx) {
        var btn = item.querySelector(".faq-q");
        var panel = item.querySelector(".faq-a");
        panel.id = "faq-panel-" + (idx + 1);
        btn.setAttribute("aria-controls", panel.id);
        panel.hidden = true;
        btn.addEventListener("click", function () {
          var isOpen = item.classList.contains("open");
          faqItems.forEach(function (other) {
            if (other.classList.contains("open")) { closeFaq(other); }
          });
          if (!isOpen) {
            clearTimeout(panel._hideTimer);
            panel.hidden = false;
            void panel.offsetHeight;
            item.classList.add("open");
            btn.setAttribute("aria-expanded", "true");
            panel.style.maxHeight = panel.scrollHeight + "px";
          }
          setTimeout(updateProgress, 350);
        });
      });
      window.addEventListener("resize", function () {
        var openPanel = document.querySelector(".faq-item.open .faq-a");
        if (openPanel) { openPanel.style.maxHeight = openPanel.scrollHeight + "px"; }
      });

      /* ---------- Forms → mailto ---------- */
      var CONTACT = {{ site.contactEmail | dump | safe }};

      function buildMailto(subject, lines) {
        return "mailto:" + CONTACT +
          "?subject=" + encodeURIComponent(subject) +
          "&body=" + encodeURIComponent(lines.join("\n"));
      }

      function hookForm(id, subjectPrefix, fieldsFn) {
        var form = document.getElementById(id);
        form.addEventListener("submit", function (e) {
          e.preventDefault();
          if (!form.checkValidity()) {
            form.reportValidity();
            return;
          }
          var data = new FormData(form);
          var get = function (k) { return (data.get(k) || "").toString().trim(); };
          var btn = form.querySelector('button[type="submit"]');
          var label = btn.textContent;
          btn.disabled = true;
          btn.textContent = "Sending…";
          fetch("/", {
            method: "POST",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: new URLSearchParams(data).toString(),
          })
            .then(function (r) {
              if (!r.ok) { throw new Error("HTTP " + r.status); }
              var note = document.createElement("p");
              note.className = "form-success";
              note.setAttribute("role", "status");
              note.textContent = "Sent — thank you! We'll get back to you within a couple of days.";
              form.replaceWith(note);
            })
            .catch(function () {
              btn.disabled = false;
              btn.textContent = label;
              window.location.href = buildMailto(subjectPrefix, fieldsFn(get));
            });
        });
      }

      hookForm("brandForm", "COVERED — Advertising enquiry", function (get) {
        return [
          "Hi COVERED team,",
          "",
          "Please could you send over the media kit? We're interested in advertising on your dispensers.",
          "",
          "Name: " + get("name"),
          "Company: " + get("company"),
          "Email: " + get("email"),
          "Indicative monthly budget: " + (get("budget") || "Not specified"),
          "Preferred campaign timing: " + (get("timing") || "Not specified"),
          "",
          "Goals:",
          get("message") || "-",
          "",
          "Thanks!"
        ];
      });

      hookForm("venueForm", "COVERED — Venue hosting enquiry", function (get) {
        return [
          "Hi COVERED team,",
          "",
          "We're interested in hosting a dispenser.",
          "",
          "Name: " + get("name"),
          "Venue: " + get("venue"),
          "Email: " + get("email"),
          "Venue type: " + get("type"),
          "",
          "Notes:",
          get("message") || "-",
          "",
          "Thanks!"
        ];
      });

      /* ---------- Scrollspy ---------- */
      var spyLinks = Array.prototype.slice.call(document.querySelectorAll('.nav-links a[href^="#"]:not(.btn)'));
      if ("IntersectionObserver" in window && spyLinks.length) {
        var spyMap = {};
        spyLinks.forEach(function (a) { spyMap[a.getAttribute("href").slice(1)] = a; });
        var spy = new IntersectionObserver(function (entries) {
          entries.forEach(function (en) {
            if (en.isIntersecting && spyMap[en.target.id]) {
              spyLinks.forEach(function (a) { a.classList.remove("active"); a.removeAttribute("aria-current"); });
              spyMap[en.target.id].classList.add("active");
              spyMap[en.target.id].setAttribute("aria-current", "true");
            }
          });
        }, { rootMargin: "-40% 0px -55% 0px" });
        Object.keys(spyMap).forEach(function (id) {
          var sec = document.getElementById(id);
          if (sec) { spy.observe(sec); }
        });
      }

      /* ---------- Launch-notify mini form ---------- */
      var notifyForm = document.getElementById("notifyForm");
      if (notifyForm) {
        notifyForm.addEventListener("submit", function (e) {
          e.preventDefault();
          if (!notifyForm.checkValidity()) { notifyForm.reportValidity(); return; }
          fetch("/", {
            method: "POST",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: new URLSearchParams(new FormData(notifyForm)).toString(),
          }).then(function (r) {
            if (!r.ok) { throw new Error("HTTP " + r.status); }
            var ok = document.createElement("p");
            ok.className = "form-success";
            ok.setAttribute("role", "status");
            ok.textContent = "You're on the list — we'll email you the moment Exeter goes live.";
            notifyForm.replaceWith(ok);
          }).catch(function () {
            window.location.href = "mailto:" + CONTACT + "?subject=" + encodeURIComponent("Tell me when Exeter goes live");
          });
        });
      }
    })();
  </script>
</body>
</html>
